# Environment variables for TempHist
# Copy this file to .env and adjust values as needed

# API Base URL (used by both client-side and server-side scripts)
# VITE_API_BASE=https://api.temphist.com

# For local development, set VITE_API_BASE to your local API server
# For dev deployment, set VITE_API_BASE to your dev API server
# For production, set VITE_API_BASE to your production API server

# Test Token for local development (used by server-local.js proxy)
# VITE_TEST_TOKEN=your_token_here

# Backend API URL for local development proxy (used by server-local.js)
# API_BASE=http://localhost:8000

# Note: Each environment (dev, staging, production) should have its own API server

# reCAPTCHA v3 site key for Firebase App Check (get from console.cloud.google.com/security/recaptcha)
# Register your domain(s) there, then enable App Check in the Firebase console
# Without this set, App Check is disabled and the API is unprotected
# VITE_RECAPTCHA_SITE_KEY=your_site_key_here
