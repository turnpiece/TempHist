{
  "name": "temphist",
  "version": "1.2.16",
  "description": "Daily temperature history chart. Shows the temperature on the same day each year over the past 50 years for the current location.",
  "main": "src/main.ts",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "start": "node server.js",
    "start:local": "node server-local.js",
    "dev": "vite",
    "build": "npx tsc && npx vite build",
    "type-check": "npx tsc --noEmit",
    "preview": "vite preview",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "version:show": "echo $npm_package_version",
    "postversion": "git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turnpiece/TempHist.git"
  },
  "keywords": [],
  "author": "Paul Jenkins",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/turnpiece/TempHist/issues"
  },
  "homepage": "https://github.com/turnpiece/TempHist#readme",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^11.9.1",
    "http-proxy-middleware": "^3.0.7"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "axios": "^1.18.0",
    "clean-css-cli": "^5.6.3",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0",
    "sharp": "^0.35.2",
    "terser": "^5.48.0",
    "to-ico": "^1.1.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
